{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cx-backend/error-envelope.v1.json",
  "type": "object",
  "required": ["requestId", "ok", "error", "metrics"],
  "properties": {
    "requestId": {
      "type": ["string", "null"]
    },
    "ok": {
      "const": false
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "required": ["elapsedMs"],
      "properties": {
        "elapsedMs": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
