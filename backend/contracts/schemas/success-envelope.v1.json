{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cx-backend/success-envelope.v1.json",
  "type": "object",
  "required": ["requestId", "taskVersion", "ok", "resultModelVersion", "result", "metrics"],
  "properties": {
    "requestId": {
      "type": ["string", "null"]
    },
    "taskVersion": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "const": true
    },
    "resultModelVersion": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "object"
    },
    "metrics": {
      "type": "object",
      "required": ["elapsedMs"],
      "properties": {
        "elapsedMs": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
